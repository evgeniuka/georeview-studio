# Local runtime state
*.log
server_*.log
__pycache__/
*.py[cod]

# Internal design-review captures (not product assets)
ui_review/*.png

# Browser automation profiles and caches
ui_review/chrome_profile*/
ui_review/*profile*/
ui_review/*cache*/
ui_review/dump_dom.txt
ui_review/chrome_dump_err.txt
# Headless-browser profile state can be regenerated under any artifact dir
**/browser_profile/
**/chrome_profile*/

# Environment, auth, and session material
.env
.env.*
auth.json
cap_sid
installation_id
*session*
*capability*

# Source GIS data must stay outside public repository packages
*.osm.pbf
*.shp
*.shp.zip
*.dbf
*.prj
*.cpg
*.gpkg
source_data/

# AI-assisted working notes (kept local, out of the published repo)
Контекст.md

# Test-suite output artifacts (written by the suites, never read by the app)
api_contract_summary.json
validation_summary.json

# Runtime state the app auto-creates when run against the bundled demo store
demo_data/analysis_output/georeview_studio_review_decisions/
demo_data/analysis_output/georeview_studio_runs/
